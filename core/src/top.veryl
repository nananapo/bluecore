import eei::*;

module top (
    clk: input clock,
    rst: input reset,
) {
    inst membus: membus_if::<MEM_DATA_WIDTH, MEM_ADDR_WIDTH>;

    inst mem: memory::<MEM_DATA_WIDTH, MEM_ADDR_WIDTH> #(
        FILEPATH_IS_ENV: 1                 ,
        FILEPATH       : "MEMORY_FILE_PATH",
    ) (
        clk     ,
        rst     ,
        membus  ,
    );
}
